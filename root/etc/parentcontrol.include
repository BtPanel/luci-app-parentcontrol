[ -x /etc/init.d/parentcontrol ] || chmod 755 /etc/init.d/parentcontrol
if [ "$(uci -q get parentcontrol.@basic[0].enabled)" = "1" ]; then
    logger -t parentcontrol "firewall hook: reloading rules"
    /etc/init.d/parentcontrol reload
else
    logger -t parentcontrol "firewall hook: service disabled"
    /etc/init.d/parentcontrol stop
fi